# SigmaLoop production env — lives ONLY on the EC2 box at ~/SigmaLoop/deploy/.env.prod
# Copy and fill in:   cp .env.prod.example .env.prod && nano .env.prod
# NEVER commit .env.prod. CI never sees these — secrets stay on the box.

# ---- API ----
JWT_SECRET=                 # 64+ hex chars. Generate:
                            #   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d

# ---- AI providers (set at least one) ----
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# ---- Qwen lesson-hint model (optional; off unless you host it) ----
QWEN_HINT_ENABLED=false

# ---- Judge0 internal secrets (any strong random strings) ----
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# NOTE: DATABASE_URL and JUDGE0_DASHBOARD are injected by docker-compose.prod.yml
# (they point at the internal `mongo` and `judge0-server` services), so you do
# not set them here.
